<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.neutrino.mapper.ReviewMapper" >
    <resultMap id="ReviewResultMap" type="com.neutrino.entity.Review">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="target_id" property="targetId" />
        <result column="target_type" property="targetType" />
        <result column="rating" property="rating" />
        <result column="content" property="content" />
        <result column="create_time" property="createTime" />
        <result column="state" property="state" />
        <association property="user" javaType="com.neutrino.entity.User" column="user_id" select="com.neutrino.mapper.UserMapper.getUserById" />
        <association property="scenic" javaType="com.neutrino.entity.Scenic" column="target_id" select="com.neutrino.mapper.ScenicMapper.getScenicById" />
        <association property="food" javaType="com.neutrino.entity.TastyFood" column="target_id" select="com.neutrino.mapper.FoodMapper.getFoodById" />
    </resultMap>
    <insert id="insert" parameterType="com.neutrino.entity.Review">
        insert into REVIEW(
        user_id,
        target_id,
        target_type,
        rating,
        content,
        create_time,
        state
        )
        values(
        #{userId,jdbcType=VARCHAR},
        #{targetId,jdbcType=INTEGER},
        #{targetType,jdbcType=INTEGER},
        #{rating,jdbcType=INTEGER},
        #{content,jdbcType=VARCHAR},
        #{createTime,jdbcType=TIMESTAMP},
        #{state,jdbcType=INTEGER}
        )
    </insert>

    <update id="update" parameterType="com.neutrino.entity.Review">
        update REVIEW
        <set>
            <if test="rating != null">rating=#{rating,jdbcType=INTEGER},</if>
            <if test="content != null">content=#{content,jdbcType=VARCHAR},</if>
            <if test="state != null">state=#{state,jdbcType=INTEGER},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="delete" parameterType="java.lang.Integer">
        delete from REVIEW where id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Integer" resultMap="ReviewResultMap">
        select * from REVIEW where id = #{id}
    </select>

    <select id="selectByTarget" resultMap="ReviewResultMap">
        select * from REVIEW
        where target_id = #{targetId} and target_type = #{targetType} and state = 1
        order by create_time desc
    </select>

    <select id="selectByUser" parameterType="java.lang.String" resultMap="ReviewResultMap">
        select * from REVIEW
        where user_id = #{userId}
        order by create_time desc
    </select>

    <select id="selectAll" resultMap="ReviewResultMap">
        select * from REVIEW
        order by create_time desc
    </select>

    <select id="selectByState" parameterType="java.lang.Integer" resultMap="ReviewResultMap">
        select * from REVIEW
        where state = #{state}
        order by create_time desc
    </select>
</mapper>