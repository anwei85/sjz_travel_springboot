<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.neutrino.mapper.FavoritesMapper" >
    <resultMap id="FavoritesResultMap" type="com.neutrino.entity.Favorites">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="target_id" property="targetId" />
        <result column="target_type" property="targetType" />
        <result column="create_time" property="createTime" />
        <association property="scenic" javaType="com.neutrino.entity.Scenic" column="target_id" select="com.neutrino.mapper.ScenicMapper.getScenicById" />
        <association property="food" javaType="com.neutrino.entity.TastyFood" column="target_id" select="com.neutrino.mapper.FoodMapper.getFoodById" />
    </resultMap>

    <insert id="insert" parameterType="com.neutrino.entity.Favorites">
        insert into COLLECTION(
        user_id,
        target_id,
        target_type,
        create_time
        )
        values(
        #{userId,jdbcType=VARCHAR},
        #{targetId,jdbcType=INTEGER},
        #{targetType,jdbcType=INTEGER},
        #{createTime,jdbcType=TIMESTAMP}
        )
    </insert>

    <delete id="delete" parameterType="java.lang.Integer">
        delete from COLLECTION where id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Integer" resultMap="FavoritesResultMap">
        select * from COLLECTION where id = #{id}
    </select>

    <select id="selectByUserAndTarget" resultMap="FavoritesResultMap">
        select * from COLLECTION
        where user_id = #{userId} and target_id = #{targetId} and target_type = #{targetType}
    </select>

    <select id="selectByUser" parameterType="java.lang.String" resultMap="FavoritesResultMap">
        select * from COLLECTION
        where user_id = #{userId}
        order by create_time desc
    </select>

    <select id="selectByTarget" resultMap="FavoritesResultMap">
        select * from COLLECTION
        where target_id = #{targetId} and target_type = #{targetType}
    </select>

    <select id="selectAll" resultMap="FavoritesResultMap">
        select * from COLLECTION
        order by create_time desc
    </select>
</mapper>